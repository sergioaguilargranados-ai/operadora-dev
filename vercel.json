{
    "framework": "nextjs",
    "buildCommand": "next build",
    "crons": [
        {
            "path": "/api/cron/hr-alerts",
            "schedule": "0 14 * * *"
        },
        {
            "path": "/api/cron/email-reminders",
            "schedule": "0 16 * * *"
        },
        {
            "path": "/api/cron/megatravel-sync",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/update-rates",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/cron/update-weather",
            "schedule": "0 * * * *"
        }
    ]
}