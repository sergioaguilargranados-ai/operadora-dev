# ═══════════════════════════════════════════════════════════════
# 🔐 AS OPERADORA - VARIABLES DE ENTORNO
# ═══════════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env.local: cp .env.example .env.local
# 2. Llena las credenciales reales (nunca subas .env.local a Git)
# 3. Ejecuta: node check-api-config.js para verificar
#
# ═══════════════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql://...

# JWT & Security
JWT_SECRET=your-jwt-secret-here
ENCRYPTION_SECRET_KEY=your-encryption-key-here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# Facturama (Mexican invoicing)
FACTURAMA_USER=your-facturama-user
FACTURAMA_PASSWORD=your-facturama-password
FACTURAMA_SANDBOX=true

# ============================================
# AMADEUS API - Self-Service
# ============================================
# Get credentials at: https://developers.amadeus.com/
# Same credentials work for all Amadeus services:
# - Flights (already implemented)
# - Hotels (NEW - 150,000+ hotels with photos)
# - Transfers/Cars (NEW - private/shared transfers)
# - Activities (NEW - 300,000+ tours from Viator/GetYourGuide)
# - City Search & POI

AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret
AMADEUS_ENVIRONMENT=test # or 'production'

# ============================================
# BOOKING.COM API (Complementary for hotels)
# ============================================
# Used to complement Amadeus hotel inventory
BOOKING_API_KEY=your-booking-api-key

# ============================================
# KIWI.COM API (Flights)
# ============================================
KIWI_API_KEY=your-kiwi-api-key

# ============================================
# EXPEDIA API (Flights/Hotels backup)
# ============================================
EXPEDIA_API_KEY=your-expedia-api-key
EXPEDIA_API_SECRET=your-expedia-api-secret

# ───────────────────────────────────────────────────────────────
# 🗄️ DATABASE (OBLIGATORIO)
# ───────────────────────────────────────────────────────────────
# PostgreSQL en Neon (o cualquier PostgreSQL)
# Obtener en: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ───────────────────────────────────────────────────────────────
# 🔐 SEGURIDAD (OBLIGATORIO)
# ───────────────────────────────────────────────────────────────
# Genera un secreto aleatorio de 32+ caracteres
# Ejemplo: openssl rand -base64 32
JWT_SECRET=tu_secreto_minimo_32_caracteres_aqui

# Ambiente de ejecución
NODE_ENV=development

# URL pública de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clave secreta para cron jobs
CRON_SECRET_KEY=tu_cron_secret_key_aqui

# ───────────────────────────────────────────────────────────────
# ✈️ AMADEUS API - Vuelos (RECOMENDADO - GRATIS)
# ───────────────────────────────────────────────────────────────
# Registro: https://developers.amadeus.com/register
# Documentación: https://developers.amadeus.com/self-service
# Costo: GRATIS en sandbox, $0.002/búsqueda en producción
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_SANDBOX=true

# ───────────────────────────────────────────────────────────────
# ✈️ KIWI.COM API - Vuelos Low-Cost (OPCIONAL)
# ───────────────────────────────────────────────────────────────
# Registro: https://tequila.kiwi.com/portal/login
# Documentación: https://tequila.kiwi.com/portal/docs
# Costo: GRATIS hasta 1000 requests/mes
KIWI_API_KEY=

# ───────────────────────────────────────────────────────────────
# 🏨 EXPEDIA API - Vuelos + Hoteles + Paquetes (OPCIONAL)
# ───────────────────────────────────────────────────────────────
# Registro: https://developers.expediagroup.com/
# Requiere aprobación (1-2 semanas)
EXPEDIA_API_KEY=
EXPEDIA_API_SECRET=
EXPEDIA_SANDBOX=true

# ───────────────────────────────────────────────────────────────
# 🏨 BOOKING.COM API - Hoteles (OPCIONAL)
# ───────────────────────────────────────────────────────────────
# Registro: https://www.booking.com/affiliate
# Requiere aprobación manual
BOOKING_API_KEY=

# ───────────────────────────────────────────────────────────────
# 📊 GOOGLE ANALYTICS - Tracking (RECOMENDADO)
# ───────────────────────────────────────────────────────────────
# Registro: https://analytics.google.com/
# Costo: GRATIS
NEXT_PUBLIC_GA_ID=

# ───────────────────────────────────────────────────────────────
# 🤖 OPENAI API - Chatbot + IA (RECOMENDADO)
# ───────────────────────────────────────────────────────────────
# Registro: https://platform.openai.com/
# Costo: $5 crédito inicial, ~$0.002/1000 tokens
OPENAI_API_KEY=

# ───────────────────────────────────────────────────────────────
# 📧 SENDGRID - Emails (RECOMENDADO)
# ───────────────────────────────────────────────────────────────
# Registro: https://signup.sendgrid.com/
# Costo: GRATIS hasta 100 emails/día
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@asoperadora.com

# ───────────────────────────────────────────────────────────────
# 💳 STRIPE - Procesamiento de Pagos (CRÍTICO - OBLIGATORIO)
# ───────────────────────────────────────────────────────────────
# Registro: https://dashboard.stripe.com/register
# Documentación: https://stripe.com/docs
# Costo: 2.9% + $0.30 por transacción
# Test Cards: https://stripe.com/docs/testing

# Clave pública (se usa en frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Clave secreta (se usa en backend)
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret (para verificar webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ───────────────────────────────────────────────────────────────
# 💰 PAYPAL - Procesamiento de Pagos (CRÍTICO - OBLIGATORIO)
# ───────────────────────────────────────────────────────────────
# Registro: https://developer.paypal.com/
# Documentación: https://developer.paypal.com/docs/api/overview/
# Costo: 3.49% + $0.49 por transacción
# Test Accounts: https://developer.paypal.com/developer/accounts/

# Client ID
PAYPAL_CLIENT_ID=

# Client Secret
PAYPAL_CLIENT_SECRET=

# Webhook ID (para verificar webhooks)
PAYPAL_WEBHOOK_ID=

# ───────────────────────────────────────────────────────────────
# 🔐 ENCRIPTACIÓN - Datos Sensibles (CRÍTICO - OBLIGATORIO)
# ───────────────────────────────────────────────────────────────
# Clave secreta para encriptar datos sensibles (pasaportes, tarjetas, etc.)
# Generar: openssl rand -base64 32
# IMPORTANTE: NO compartir, NO cambiar en producción (se pierden datos)
ENCRYPTION_SECRET_KEY=tu_clave_secreta_minimo_32_caracteres_aqui_generada_aleatoria

# ───────────────────────────────────────────────────────────────
# 📁 VERCEL BLOB - Almacenamiento de Documentos (CRÍTICO)
# ───────────────────────────────────────────────────────────────
# Storage para documentos sensibles (pasaportes, visas, IDs)
# Obtener en: https://vercel.com/dashboard/stores
# Documentación: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=

# ───────────────────────────────────────────────────────────────
# 💳 STRIPE - Pagos (OPCIONAL)
# ───────────────────────────────────────────────────────────────
# Registro: https://dashboard.stripe.com/register
# Costo: 3.6% + $3 MXN por transacción
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ───────────────────────────────────────────────────────────────
# 💬 TWILIO - WhatsApp + SMS (OPCIONAL)
# ───────────────────────────────────────────────────────────────
# Registro: https://www.twilio.com/try-twilio
# Costo: $15 USD crédito inicial
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# ───────────────────────────────────────────────────────────────
# ☁️ CLOUDFLARE R2 - Almacenamiento de Archivos (OPCIONAL)
# ───────────────────────────────────────────────────────────────
# Registro: https://dash.cloudflare.com/
# Costo: GRATIS hasta 10GB
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ═══════════════════════════════════════════════════════════════
# 📊 CONFIGURACIÓN ADICIONAL
# ═══════════════════════════════════════════════════════════════

# Timezone
TZ=America/Mexico_City

# Idioma predeterminado
DEFAULT_LOCALE=es-MX

# Moneda predeterminada
DEFAULT_CURRENCY=MXN

# ═══════════════════════════════════════════════════════════════
# 🎯 PRIORIDADES PARA EMPEZAR
# ═══════════════════════════════════════════════════════════════
#
# 1. DATABASE_URL (OBLIGATORIO)
# 2. JWT_SECRET (OBLIGATORIO)
# 3. AMADEUS_API_KEY + AMADEUS_API_SECRET (búsqueda de vuelos reales)
# 4. SENDGRID_API_KEY (envío de emails)
# 5. OPENAI_API_KEY (chatbot con IA)
#
# Las demás son opcionales y se pueden agregar después
#
# ═══════════════════════════════════════════════════════════════
